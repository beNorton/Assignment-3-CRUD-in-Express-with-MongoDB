<%- include('header', { title: title }) %>
    <div class="page-content">  
        <h1>Meal Details</h1>
        <% if (meals) { %>
        <div class="meal-item">
            <h1><%= title %></h1>
            <p><%= description %></p>
            <div class="meal-image">
                <img src="<%= plateImageURL %>" alt="<%= title %>">
        </div>
        <% } else { %>
        <p>Meal not found.</p>
        <% } %>
        <p>
        <a href="/">Back to home</a>
        </p>
    </div>
</body>
</html>